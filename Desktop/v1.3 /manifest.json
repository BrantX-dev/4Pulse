{
  "manifest_version": 3,
  "name": "4Pulse",
  "version": "1.3",
  "description": "Твой пульс форума 4PDA — мгновенные уведомления о новых ответах, QMS и упоминаниях в любимых темах.",
  "homepage_url": "https://4pda.to/",
  "icons": {
    "48": "img/icons/icon_48.png",
    "128": "img/icons/icon_128.png"
  },
  "action": {
    "default_icon": {
      "16": "img/icons/icon_48.png",
      "19": "img/icons/icon_48.png",
      "32": "img/icons/icon_48.png",
      "48": "img/icons/icon_48.png"
    },
    "default_title": "4Pulse",
    "default_popup": "html/popup.html"
  },
  "sidebar_action": {
    "default_icon": {
      "16": "img/icons/icon_48.png",
      "19": "img/icons/icon_48.png",
      "32": "img/icons/icon_48.png",
      "48": "img/icons/icon_48.png"
    },
    "default_title": "4Pulse",
    "default_panel": "html/sidebar.html",
    "open_at_install": false
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://4pda.to/forum/index.php*"
      ],
      "js": [
        "js/page_watcher.js"
      ],
      "run_at": "document_end"
    }
  ],
  "options_page": "html/options.html",
  "host_permissions": [
    "https://4pda.to/",
    "https://fonts.googleapis.com/",
    "https://fonts.gstatic.com/",
    "https://de1.api.radio-browser.info/",
    "*://*.hostingradio.ru/*",
    "*://*.pcradio.ru/*",
    "*://online.hitfm.ua/*",
    "*://online.kissfm.ua/*",
    "*://icecast.luxfm.kz/*",
    "*://icecast.ns.kz/*",
    "*://icecast-vgtrk.cdnvideo.ru/*",
    "*://ice6.somafm.com/*",
    "*://online.radioroks.ua/*",
    "*://streams.ilovemusic.de/*",
    "*://radio-srv1.11one.ru/*"
  ],
  "permissions": [
    "alarms",
    "cookies",
    "notifications",
    "storage",
    "scripting",
    "idle",
    "contextMenus",
    "tabs"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "sounds/*.ogg"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "4pulse@brantx",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}